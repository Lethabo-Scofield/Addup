# ── AI (OpenRouter) ──────────────────────────────────────────────────────────
# Used by the /api/explain endpoint for Grok AI explanations.
# On Replit: set automatically via the OpenRouter AI integration.
# On Vercel: get your API key from https://openrouter.ai/keys
AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-...
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Used for the waitlist feature.
# On Replit: provisioned automatically.
# On Vercel: use Vercel Postgres, Neon, or any external PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/dbname

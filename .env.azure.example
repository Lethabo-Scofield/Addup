# ─────────────────────────────────────────────────────────────────────────────
# Addup — Azure environment variables
#
# Copy this file to .env (never commit .env to git).
# Set each value in Azure App Service → Configuration → Application settings,
# or add them as GitHub Actions secrets for CI/CD.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database (Azure Database for PostgreSQL Flexible Server) ──────────────────
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://addup_admin:YOUR_PASSWORD@addup-postgres.postgres.database.azure.com/addup?sslmode=require

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Frontend build (Vite — set at build time, not runtime) ───────────────────
# The public URL of the API, used in Vite's build output.
VITE_API_URL=https://addup-api.azurewebsites.net

# ── GitHub Actions secrets (add these in repo Settings → Secrets) ─────────────
# AZURE_CREDENTIALS          — JSON output of: az ad sp create-for-rbac --sdk-auth
# AZURE_STATIC_WEB_APPS_API_TOKEN — from: az staticwebapp secrets list --name addup-frontend
# DATABASE_URL               — same as above
# RESEND_API_KEY             — same as above
